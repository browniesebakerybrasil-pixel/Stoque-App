# ============================================================================
# Stoque — variáveis de ambiente (exemplo / template)
#
# Copie este arquivo para `.env.local` e preencha com as credenciais reais.
# `.env.local` está no .gitignore — nunca comite segredos.
# ============================================================================

# ----- Supabase ------------------------------------------------------------
# Dashboard: https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ----- Clerk ---------------------------------------------------------------
# Dashboard: https://dashboard.clerk.com -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Webhook signing secret do Clerk (Dashboard -> Webhooks)
# Configurar o endpoint apontando para /api/webhooks/clerk
CLERK_WEBHOOK_SECRET=whsec_...

# ----- Stripe --------------------------------------------------------------
# Dashboard: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Gerado por `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs criados no dashboard do Stripe (3 produtos recorrentes em BRL)
NEXT_PUBLIC_STRIPE_PRICE_BASICO=price_...
NEXT_PUBLIC_STRIPE_PRICE_FULL=price_...
NEXT_PUBLIC_STRIPE_PRICE_MASTER=price_...

# ----- App -----------------------------------------------------------------
# URL pública do app (usada nos redirects do Stripe). Em produção, trocar.
NEXT_PUBLIC_APP_URL=http://localhost:3000
